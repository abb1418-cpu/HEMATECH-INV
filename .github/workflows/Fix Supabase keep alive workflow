name: Keep Supabase Alive

on:
  schedule:
    # يعمل 3 مرات يوميًا:
    # 03:17 صباحًا بتوقيت السعودية
    # 11:17 صباحًا بتوقيت السعودية
    # 07:17 مساءً بتوقيت السعودية
    - cron: '17 0,8,16 * * *'

  workflow_dispatch:

permissions:
  contents: read

jobs:
  ping:
    name: Ping Supabase
    runs-on: ubuntu-latest
    timeout-minutes: 3

    steps:
      - name: Call Supabase Keep Alive
        env:
          SUPABASE_URL: ${{ secrets.SUPABASE_URL }}
          SUPABASE_KEY: ${{ secrets.SUPABASE_PUBLISHABLE_KEY }}

        run: |
          set -euo pipefail

          if [ -z "${SUPABASE_URL:-}" ]; then
            echo "SUPABASE_URL secret is missing"
            exit 1
          fi

          if [ -z "${SUPABASE_KEY:-}" ]; then
            echo "SUPABASE_PUBLISHABLE_KEY secret is missing"
            exit 1
          fi

          RESPONSE_FILE=$(mktemp)

          STATUS=$(curl \
            --silent \
            --show-error \
            --location \
            --retry 3 \
            --retry-delay 10 \
            --connect-timeout 15 \
            --max-time 30 \
            --request POST \
            --output "$RESPONSE_FILE" \
            --write-out "%{http_code}" \
            "${SUPABASE_URL}/rest/v1/rpc/keep_alive" \
            --header "apikey: ${SUPABASE_KEY}" \
            --header "Content-Type: application/json" \
            --data '{}')

          echo "HTTP status: $STATUS"
          echo "Supabase response:"
          cat "$RESPONSE_FILE"
          echo

          if [ "$STATUS" -lt 200 ] || [ "$STATUS" -ge 300 ]; then
            echo "Supabase keep-alive failed"
            exit 1
          fi

          echo "Supabase keep-alive completed successfully"
